Defaults:spotpi !requiretty

Cmnd_Alias PCS_SYSTEMCTL = \
  /bin/systemctl start spotpi-librespot.service, \
  /bin/systemctl stop spotpi-librespot.service, \
  /bin/systemctl restart spotpi-librespot.service, \
  /bin/systemctl enable spotpi-librespot.service, \
  /bin/systemctl enable --now spotpi-librespot.service, \
  /bin/systemctl disable spotpi-librespot.service, \
  /bin/systemctl disable --now spotpi-librespot.service, \
  /usr/bin/systemctl start spotpi-librespot.service, \
  /usr/bin/systemctl stop spotpi-librespot.service, \
  /usr/bin/systemctl restart spotpi-librespot.service, \
  /usr/bin/systemctl enable spotpi-librespot.service, \
  /usr/bin/systemctl enable --now spotpi-librespot.service, \
  /usr/bin/systemctl disable spotpi-librespot.service, \
  /usr/bin/systemctl disable --now spotpi-librespot.service

Cmnd_Alias PCS_JOURNALCTL = \
  /bin/journalctl -u spotpi-librespot.service *, \
  /bin/journalctl -u spotpi.service *, \
  /usr/bin/journalctl -u spotpi-librespot.service *, \
  /usr/bin/journalctl -u spotpi.service *

spotpi ALL=(root) NOPASSWD: PCS_SYSTEMCTL, PCS_JOURNALCTL
